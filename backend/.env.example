# ─────────────────────────────────────────────
#  Métricas LikeHome — Backend Environment
#  Copie este arquivo como .env e ajuste os valores
# ─────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troca_por_um_segredo_forte_e_aleatorio
JWT_EXPIRES_IN=8h

# Caminho do banco de dados SQLite
DB_PATH=/opt/metricas-likehome/backend/data/database.sqlite

# Origem permitida para CORS (domínio ou IP do seu servidor)
# Ex: https://metricas.seudominio.com.br  ou  http://192.168.1.10
ALLOWED_ORIGIN=https://metricas.seudominio.com.br
